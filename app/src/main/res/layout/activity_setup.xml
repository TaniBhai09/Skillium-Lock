<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_screen">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/margin_medium" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_medium"
        android:gravity="center"
        android:layout_marginBottom="@dimen/margin_large" />

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:hint="@string/setup_admin_name"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="@dimen/text_medium"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/padding_medium"
        android:inputType="text"
        android:layout_marginBottom="@dimen/margin_medium"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:hint="@string/setup_admin_password"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="@dimen/text_medium"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/padding_medium"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:layout_marginBottom="@dimen/margin_medium"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <EditText
        android:id="@+id/confirmInput"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:hint="@string/setup_confirm_password"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="@dimen/text_medium"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/padding_medium"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:layout_marginBottom="@dimen/margin_large"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <Button
        android:id="@+id/createButton"
        style="@style/DashboardButton"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:text="@string/setup_create" />
</LinearLayout>
